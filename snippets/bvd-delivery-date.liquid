<script>
  window.onload = function() {
      if (window.jQuery) {
        let $ = window.jQuery;
        $(function() {
          $.datepicker.setDefaults( $.datepicker.regional[ "ja" ] );
          $("#date").datepicker({
          minDate: +8,
          maxDate: '+1M',
          showButtonPanel: true
        });
      });
    }
  }
</script>
