    "custom_liquid_tg7kwd": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"renewal page-width\">\n  <div class=\"renewal-card\">\n\n      <div class=\"popup-info-box\">\n          <div class=\"popup-logo-row\">\n            <span class=\"logo-bvd\"><img src=\"https://cdn.shopify.com/s/files/1/0942/4456/9367/files/logo_ex.png?v=1771395332\" alt=\"B.V.D.\"></span>\n            <span class=\"logo-sub\">OFFICIAL EXCLUSIVE<br>ONLINE STORE</span>\n          </div>\n          <p class=\"popup-desc\">\n            GOOD FAR 新ブランドの立ち上げに伴う、<br>\n            サイトリニューアルおよび取り扱いブランド<br>\n            変更のお知らせ\n          </p>\n      </div>\n\n\n    <div class=\"popup-btn-area\">\n      <a href=\"https://goodfar.jp/pages/exclusive-renewal\" class=\"popup-btn popup-btn-red\">\n        <span>お知らせはこちら</span><span class=\"arrow\">→</span>\n      </a>\n      <a href=\"https://goodfar.jp/\" class=\"popup-btn popup-btn-black\">\n        <span>GOOD FAR OFFICIAL WEBはこちら</span><span class=\"arrow\">→</span>\n      </a>\n    </div>\n\n  </div>\n</div>\n\n\n<style>\n.renewal {\n    z-index: 100000;\n    overflow-y: auto;\n    border:1px solid #efefef;\nmax-width: 710px;\n}\n.renewal .popup-info-box {\n    width: 100%;\n    \n    box-sizing: border-box;\n}\n\n.renewal .popup-logo-row {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 16px;\npadding: 30px 15% 0;\n}\n.renewal .logo-bvd{\n    max-width: 100px;\n    width: 25%;\n}\n.renewal .logo-bvd img{\n    width: 100%;\n    height: auto;\n}\n.renewal .logo-sub {\n    font-weight: 700;\n    font-size: 0.92rem;\n    line-height: 1.35;\n    color: #111;\n    letter-spacing: 0.3px;\n}\n\n.renewal .popup-desc {\n    margin: 0;\n    font-size: 1.2rem;\n    line-height: 2;\n    color: #111;\n    font-weight: 500;\ntext-align: center;\n}\n\n.renewal .popup-btn-area {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    padding: 20px 24px 50px;\n    box-sizing: border-box;\n}\n.renewal .popup-btn {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    text-decoration: none;\n    padding: 1.1rem 1.4rem;\n    font-size: 1.2rem;\n    line-height: 1.4;\n    transition: opacity 0.2s;\n}\n.renewal .popup-btn:hover { opacity: 0.85; }\n.renewal .popup-btn-red {\n    background: #e02020;\n    color: #fff;\n}\n.renewal .popup-btn-black {\n    background: #000;\n    color: #fff;\n}\n.renewal .popup-btn .arrow {\n    margin-left: 12px;\n    flex-shrink: 0;\n}\n\n/*@media screen and (min-width: 990px) {\n    .renewal .popup-content { max-width: 460px; }\n}*/\n\n@media screen and (min-width: 769px) {\n.renewal .popup-info-box{padding:30px 0 0;}\n.renewal .popup-desc{margin: 3rem auto 2rem;}\n.renewal .popup-desc br:nth-child(2){display:none;}\n.renewal .logo-sub{font-size: 1.2rem;}\n.renewal .popup-desc,.renewal .popup-btn{font-size: 1.3rem;}\n.renewal .popup-btn-area{padding: 20px 15% 50px;}\n}\n@media screen and (max-width: 768px) {\n    .renewal{margin: 0 5%;}\n}\n</style>",
